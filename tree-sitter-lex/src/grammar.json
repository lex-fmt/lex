{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "lex",
  "rules": {
    "document": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_block"
      }
    },
    "_block": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "verbatim_block"
        },
        {
          "type": "SYMBOL",
          "name": "annotation_block"
        },
        {
          "type": "SYMBOL",
          "name": "annotation_single"
        },
        {
          "type": "SYMBOL",
          "name": "definition"
        },
        {
          "type": "SYMBOL",
          "name": "session"
        },
        {
          "type": "SYMBOL",
          "name": "list"
        },
        {
          "type": "SYMBOL",
          "name": "paragraph"
        },
        {
          "type": "SYMBOL",
          "name": "blank_line"
        }
      ]
    },
    "session": {
      "type": "PREC_DYNAMIC",
      "value": 1,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "FIELD",
            "name": "title",
            "content": {
              "type": "SYMBOL",
              "name": "line_content"
            }
          },
          {
            "type": "SYMBOL",
            "name": "_newline"
          },
          {
            "type": "REPEAT1",
            "content": {
              "type": "SYMBOL",
              "name": "blank_line"
            }
          },
          {
            "type": "SYMBOL",
            "name": "_indent"
          },
          {
            "type": "REPEAT1",
            "content": {
              "type": "SYMBOL",
              "name": "_block"
            }
          },
          {
            "type": "SYMBOL",
            "name": "_dedent"
          }
        ]
      }
    },
    "verbatim_block": {
      "type": "PREC_DYNAMIC",
      "value": 4,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "FIELD",
            "name": "subject",
            "content": {
              "type": "SYMBOL",
              "name": "line_content"
            }
          },
          {
            "type": "SYMBOL",
            "name": "_newline"
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "SYMBOL",
              "name": "blank_line"
            }
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SEQ",
                "members": [
                  {
                    "type": "SYMBOL",
                    "name": "_indent"
                  },
                  {
                    "type": "REPEAT1",
                    "content": {
                      "type": "SYMBOL",
                      "name": "_block"
                    }
                  },
                  {
                    "type": "SYMBOL",
                    "name": "_dedent"
                  }
                ]
              },
              {
                "type": "BLANK"
              }
            ]
          },
          {
            "type": "SYMBOL",
            "name": "annotation_marker"
          },
          {
            "type": "SYMBOL",
            "name": "annotation_header"
          },
          {
            "type": "SYMBOL",
            "name": "annotation_marker"
          },
          {
            "type": "SYMBOL",
            "name": "_newline"
          }
        ]
      }
    },
    "definition": {
      "type": "PREC_DYNAMIC",
      "value": 2,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "FIELD",
            "name": "subject",
            "content": {
              "type": "SYMBOL",
              "name": "line_content"
            }
          },
          {
            "type": "SYMBOL",
            "name": "_newline"
          },
          {
            "type": "SYMBOL",
            "name": "_indent"
          },
          {
            "type": "REPEAT1",
            "content": {
              "type": "SYMBOL",
              "name": "_block"
            }
          },
          {
            "type": "SYMBOL",
            "name": "_dedent"
          }
        ]
      }
    },
    "list": {
      "type": "PREC_DYNAMIC",
      "value": 3,
      "content": {
        "type": "PREC_RIGHT",
        "value": 0,
        "content": {
          "type": "SEQ",
          "members": [
            {
              "type": "SYMBOL",
              "name": "list_item"
            },
            {
              "type": "REPEAT1",
              "content": {
                "type": "SYMBOL",
                "name": "list_item"
              }
            }
          ]
        }
      }
    },
    "list_item": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "list_item_line"
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "_indent"
                },
                {
                  "type": "REPEAT1",
                  "content": {
                    "type": "SYMBOL",
                    "name": "_block"
                  }
                },
                {
                  "type": "SYMBOL",
                  "name": "_dedent"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "annotation_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "annotation_marker"
        },
        {
          "type": "SYMBOL",
          "name": "annotation_header"
        },
        {
          "type": "SYMBOL",
          "name": "annotation_marker"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "ALIAS",
              "content": {
                "type": "SYMBOL",
                "name": "text_content"
              },
              "named": true,
              "value": "annotation_inline_text"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        },
        {
          "type": "SYMBOL",
          "name": "_indent"
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "SYMBOL",
            "name": "_block"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_dedent"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "annotation_end_marker"
                },
                {
                  "type": "SYMBOL",
                  "name": "_newline"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "annotation_single": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "annotation_marker"
        },
        {
          "type": "SYMBOL",
          "name": "annotation_header"
        },
        {
          "type": "SYMBOL",
          "name": "annotation_marker"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "ALIAS",
              "content": {
                "type": "SYMBOL",
                "name": "text_content"
              },
              "named": true,
              "value": "annotation_inline_text"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "annotation_header": {
      "type": "PATTERN",
      "value": "[^\\n:]+"
    },
    "paragraph": {
      "type": "PREC_RIGHT",
      "value": -1,
      "content": {
        "type": "REPEAT1",
        "content": {
          "type": "SYMBOL",
          "name": "text_line"
        }
      }
    },
    "text_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "line_content"
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "line_content": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "list_item_line"
        },
        {
          "type": "SYMBOL",
          "name": "subject_content"
        },
        {
          "type": "SYMBOL",
          "name": "text_content"
        }
      ]
    },
    "subject_content": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "PATTERN",
          "value": "[^\\n]+:"
        }
      }
    },
    "text_content": {
      "type": "PATTERN",
      "value": "[^\\n]+"
    },
    "blank_line": {
      "type": "SYMBOL",
      "name": "_newline"
    }
  },
  "extras": [],
  "conflicts": [
    [
      "list_item",
      "line_content"
    ],
    [
      "session",
      "verbatim_block",
      "text_line"
    ],
    [
      "session",
      "verbatim_block"
    ],
    [
      "verbatim_block",
      "definition"
    ],
    [
      "verbatim_block",
      "text_line"
    ]
  ],
  "precedences": [],
  "externals": [
    {
      "type": "SYMBOL",
      "name": "_indent"
    },
    {
      "type": "SYMBOL",
      "name": "_dedent"
    },
    {
      "type": "SYMBOL",
      "name": "_newline"
    },
    {
      "type": "SYMBOL",
      "name": "annotation_marker"
    },
    {
      "type": "SYMBOL",
      "name": "annotation_end_marker"
    },
    {
      "type": "SYMBOL",
      "name": "list_item_line"
    }
  ],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}