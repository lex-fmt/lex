    },
    {
      "type": "SYMBOL",
      "name": "annotation_end_marker"
    },
    {
      "type": "SYMBOL",
      "name": "list_item_line"
    },
    {
      "type": "SYMBOL",
      "name": "subject_content"
    },
    {
      "type": "SYMBOL",
      "name": "_strong_open"
    },
    {
      "type": "SYMBOL",
      "name": "_strong_close"
    },
    {
      "type": "SYMBOL",
      "name": "_emphasis_open"
    },
    {
      "type": "SYMBOL",
      "name": "_emphasis_close"
    },
    {
      "type": "SYMBOL",
      "name": "_session_break"
    }
  ],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}