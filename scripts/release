#!/usr/bin/env bash
set -euo pipefail

# Cut a release. Everything runs in CI — this just triggers it.
#
# Usage:  scripts/release <new-version>       e.g. scripts/release 0.9.0
#    or:  scripts/release <bump-level>        e.g. scripts/release minor
#                                                  (one of: major, minor, patch)
#
# Pre-releases: pass a semver pre-release suffix to cut a release candidate
# or beta, e.g. scripts/release 0.9.0-rc.1.
#
# What CI does (all on GitHub):
#   1. Bumps the workspace version via `cargo set-version --workspace`
#      (handles all 7 crates + 4 workspace.dependencies pins + Cargo.lock)
#   2. Rolls ## Unreleased → ## VERSION - DATE in CHANGELOG.md
#      (final releases only — pre-releases leave Unreleased intact)
#   3. Commits "chore: Release vX.Y.Z" on main + creates+pushes tag
#   4. Creates GitHub Release with notes from CHANGELOG
#   5. Builds lexd + lexd-lsp binaries for 6 platforms
#      (mac arm64+x86_64 signed+notarized, linux x86_64-gnu+aarch64-gnu+x86_64-musl,
#      windows x86_64); both binaries signed on macOS
#   6. Builds .deb packages for lexd on linux-gnu targets, attaches to release
#   7. Publishes 6 crates to crates.io in dep order
#      (lex-core → lex-config → lex-babel → lex-analysis → lexd-lsp → lexd)
#   8. Generates Homebrew formula for lexd, pushes to arthur-debert/homebrew-tools
#
# Replaces the previous scripts/release.sh + cargo-release + tag-push
# trigger model. lex-wasm is NOT published (publish=false in its Cargo.toml).

semverParseInto() {
    local RE='[^0-9]*\([0-9]*\)[.]\([0-9]*\)[.]\([0-9]*\)\([0-9A-Za-z-]*\)'
    eval "$2"=$(echo "$1" | sed -e "s#$RE#\1#")
    eval "$3"=$(echo "$1" | sed -e "s#$RE#\2#")
    eval "$4"=$(echo "$1" | sed -e "s#$RE#\3#")
    eval "$5"=$(echo "$1" | sed -e "s#$RE#\4#")
}

if [ $# -ne 1 ]; then
    echo "usage: $(basename "$0") <major|minor|patch|X.Y.Z>" >&2
    exit 2
fi

arg="$1"
repo_root=$(git rev-parse --show-toplevel)

case "$arg" in
    major|minor|patch)
        # lex-fmt/lex doesn't use [workspace.package] version — each crate
        # has its own version line, kept in sync by cargo-release's
        # shared-version. Read the current from any crate (lex-core is
        # the foundation lib, always at the top of the dep order).
        current=$(grep -E '^version = ' "$repo_root/crates/lex-core/Cargo.toml" \
            | head -1 | sed -E 's/.*"([^"]+)".*/\1/')
        current_core="${current%%-*}"
        MAJOR=0; MINOR=0; PATCH=0; SPECIAL=""
        semverParseInto "$current_core" MAJOR MINOR PATCH SPECIAL
        case "$arg" in
            major) MAJOR=$((MAJOR + 1)); MINOR=0; PATCH=0 ;;
            minor) MINOR=$((MINOR + 1)); PATCH=0 ;;
            patch) PATCH=$((PATCH + 1)) ;;
        esac
        new_version="${MAJOR}.${MINOR}.${PATCH}"
        echo "Bumping ${arg}: ${current} -> ${new_version}"
        ;;
    *)
        if ! [[ "$arg" =~ ^[0-9]+\.[0-9]+\.[0-9]+(-[0-9A-Za-z-]+(\.[0-9A-Za-z-]+)*)?$ ]]; then
            echo "version must be MAJOR.MINOR.PATCH[-PRERELEASE] or one of: major, minor, patch (got: $arg)" >&2
            exit 2
        fi
        new_version="$arg"
        ;;
esac

if ! command -v gh >/dev/null 2>&1; then
    echo "gh CLI not found — install from https://cli.github.com/" >&2
    exit 1
fi

echo "Triggering release workflow for v${new_version}..."
gh workflow run release.yml -f version="$new_version"

echo
echo "Workflow queued. Follow with:"
echo "  gh run watch"
echo "  gh run list --workflow=release.yml --limit=1"
