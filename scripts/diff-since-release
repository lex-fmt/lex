#!/usr/bin/env bash
set -euo pipefail

# Skip pre-release tags (e.g. v0.9.0-rc.1) — we want the diff against the
# last *final* release.
latest_tag=$(git tag --list 'v*' --sort=-version:refname | grep -v -- '-' | head -n1)

if [ -z "$latest_tag" ]; then
    echo "No release tags found"
    exit 1
fi

echo "Changes since $latest_tag:"
echo "---"
git --no-pager log --oneline "$latest_tag"..HEAD
